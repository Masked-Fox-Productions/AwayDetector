{
  "format_version": "1.20.60",
  "minecraft:block": {
    "description": {
      "identifier": "awaydetector:awaydetector_block",
      "menu_category": {
        "category": "items",
        "group": "itemGroup.name.awaydetector"
      },
      "states": {
        "awaydetector:signal_strength": {
          "values": { "min": 0, "max": 15 }
        }
      }
    },
    "components": {
      "minecraft:custom_components": ["awaydetector:detector"],
      "minecraft:tick": {
        "interval_range": [20, 20],
        "looping": true
      },
      "minecraft:destructible_by_mining": {
        "seconds_to_destroy": 3.0
      },
      "minecraft:destructible_by_explosion": {
        "explosion_resistance": 15
      },
      "minecraft:map_color": "#2d7d9a",
      "minecraft:geometry": "minecraft:geometry.full_block",
      "minecraft:material_instances": {
        "*": {
          "texture": "awaydetector_block",
          "render_method": "opaque"
        }
      }
    },
    "permutations": [
      {
        "condition": "query.block_state('awaydetector:signal_strength') > 0",
        "components": {
          "minecraft:redstone_conductivity": {
            "redstone_conductor": true,
            "allows_wire_to_step_down": false
          }
        }
      }
    ]
  }
}
